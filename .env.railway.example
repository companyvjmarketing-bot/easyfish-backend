# Railway PostgreSQL service references (add these in the backend service Variables tab)
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}

# Required application secret
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_BUCKET=easyfish-images
CLOUDFLARE_R2_PUBLIC_URL=https://YOUR_PUBLIC_R2_DOMAIN
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-me
CLOUDFLARE_R2_PRESIGN_EXPIRY_SECONDS=900

# Add after Railway backend deployment
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Existing integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=otp
FAST2SMS_SENDER_ID=
FAST2SMS_TEMPLATE_ID=
